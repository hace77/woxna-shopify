{{ 'component-variant-metafield.css' | asset_url | stylesheet_tag }}
<script src="{{ 'variant-metafield-section.js' | asset_url }}" defer="defer"></script>

<variant-metafield-section 
  class="variant-metafield-section section-{{ section.id }}-padding"
  id="VariantMetafield-Section-{{ section.id }}"
  data-variant-metafield
  data-section-id="{{ section.id }}"
  data-vmd-rev="2"
>
  <div class="{% if section.settings.full_width %}page-width--full{% else %}page-width{% endif %}">
    {%- liquid
      assign namespace = 'custom'
      assign key = section.settings.metafield_key | strip
      assign variant_metafield = product.selected_or_first_available_variant.metafields[namespace][key]
    -%}
    {%- capture variant_metafield_richtext_html -%}
      {{- variant_metafield | metafield_tag -}}
    {%- endcapture -%}
    {%- comment -%} strip_html: real text check for rich text (not just HTML wrappers / whitespace) {%- endcomment -%}
    {%- assign variant_metafield_richtext_stripped = variant_metafield_richtext_html | strip_html | strip -%}
    {%- liquid
      assign variant_metafield_plain = ''
      if variant_metafield != blank and variant_metafield.type == 'rich_text_field'
        assign variant_metafield_plain = variant_metafield | metafield_text | strip
      endif
      assign variant_metafield_has_content = false
      if variant_metafield != blank
        assign metafield_type_check = variant_metafield.type
        if metafield_type_check == 'rich_text_field'
          if variant_metafield_richtext_stripped != blank
            assign variant_metafield_has_content = true
          elsif variant_metafield_plain != blank
            assign variant_metafield_has_content = true
          endif
        elsif metafield_type_check == 'file_reference'
          # File metafields can be translated in T&A; empty locale row => .value blank
          if variant_metafield.value != blank
            assign variant_metafield_has_content = true
          endif
        else
          assign variant_metafield_has_content = true
        endif
      endif
    -%}
    
    {%- if variant_metafield_has_content -%}
      <div class="variant-metafield__wrapper">
        {%- if section.settings.show_heading and section.settings.heading != blank -%}
          <h2 class="variant-metafield__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        
        <div class="variant-metafield__content">
          {%- liquid
            assign metafield_type = variant_metafield.type
            
            # Handle image/file metafields
            if metafield_type == 'file_reference'
              if variant_metafield.value != blank
                assign image_url = variant_metafield.value | image_url: width: 1200
                assign image_width = variant_metafield.value.width | default: 1200
                assign image_height = variant_metafield.value.height | default: 800
                if variant_metafield.value.aspect_ratio
                  assign image_height = image_width | divided_by: variant_metafield.value.aspect_ratio | round
                endif
                echo '<img src="' | append: image_url | append: '" alt="' | append: section.settings.heading | default: product.selected_or_first_available_variant.title | append: '" loading="lazy" width="' | append: image_width | append: '" height="' | append: image_height | append: '">'
              endif
            # Handle rich text metafields
            elsif metafield_type == 'rich_text_field'
              if variant_metafield_richtext_stripped != blank
                echo variant_metafield_richtext_html
              elsif variant_metafield_plain != blank
                assign mf_plain_out = variant_metafield | metafield_text
                echo '<div class="rte rte--metafield-plain-fallback">'
                echo mf_plain_out
                echo '</div>'
              endif
            # Handle plain text, URLs, and other metafields
            else
              # Check if it's an image URL
              if variant_metafield.value contains '.jpg' or variant_metafield.value contains '.png' or variant_metafield.value contains '.gif' or variant_metafield.value contains '.webp' or variant_metafield.value contains 'cdn.shopify.com'
                echo '<img src="' | append: variant_metafield.value | append: '" alt="' | append: section.settings.heading | default: product.selected_or_first_available_variant.title | append: '" loading="lazy" style="max-width: 100%;">'
              # Plain text or other content
              else
                echo variant_metafield.value
              endif
            endif
          -%}
        </div>
      </div>
    {%- elsif section.settings.show_fallback and section.settings.fallback_content != blank -%}
      <div class="variant-metafield__wrapper">
        {%- if section.settings.show_heading and section.settings.heading != blank -%}
          <h2 class="variant-metafield__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        <div class="variant-metafield__content">
          {{ section.settings.fallback_content }}
        </div>
      </div>
    {%- else -%}
      {%- comment -%} View Source: why this block is empty (file locale value often blank in T&A) {%- endcomment -%}
      <!-- variant-metafield-display: empty locale={{ request.locale.iso_code }} key={{ key }} variant_id={{ product.selected_or_first_available_variant.id }}{% if variant_metafield == blank %} reason=no_metafield{% elsif variant_metafield.type == 'file_reference' and variant_metafield.value == blank %} reason=file_reference_value_blank_for_locale{% elsif variant_metafield.type == 'rich_text_field' %} reason=rich_text_no_tag_no_plain{% else %} reason=no_renderable_output{% endif %} -->
    {%- endif -%}
  </div>
</variant-metafield-section>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
  .variant-metafield-section {
    opacity: 1;
    transition: opacity 0.3s ease;
  }
  
  .variant-metafield-section .variant-metafield__heading {
    text-align: {{ section.settings.text_alignment }};
    font-size: 2.4rem;
    margin-bottom: 2rem;
  }
  
  .variant-metafield-section .variant-metafield__content {
    text-align: {{ section.settings.text_alignment }};
  }
  
  {% if section.settings.full_width %}
    .page-width--full {
      max-width: 100%;
      padding: 0;
    }
    
    .page-width--full .variant-metafield__wrapper {
      max-width: 100%;
    }
    
    .page-width--full .variant-metafield__heading {
      padding: 0 2rem;
    }
  {% endif %}
  
  .variant-metafield-section .variant-metafield__content img {
    max-width: 100%;
    width: {% if section.settings.full_width %}100%{% else %}auto{% endif %};
    height: auto;
    display: {{ section.settings.image_display }};
    {% if section.settings.image_display == 'block' and section.settings.full_width == false %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
  }
</style>

{% schema %}
{
  "name": "Variant Metafield Display",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Display variant-specific content from metafields. This section can be placed anywhere in your product template and will update automatically when customers change variants."
    },
    {
      "type": "paragraph",
      "content": "File (image) metafields can appear in Translate & Adapt. If a language has an empty file row for that variant, the image will not show for that locale—remove the translation or attach the same file so it inherits from the default."
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield Key",
      "info": "Enter the metafield key (e.g., size_image, care_instructions, material_details)",
      "placeholder": "size_image"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show Heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Details",
      "info": "Optional heading to display above the metafield content"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width Image",
      "default": false,
      "info": "Make the image span the full width of the screen (edge to edge)"
    },
    {
      "type": "select",
      "id": "image_display",
      "label": "Image Display",
      "options": [
        {
          "value": "block",
          "label": "Centered"
        },
        {
          "value": "inline-block",
          "label": "Inline"
        }
      ],
      "default": "block",
      "info": "Only applies when Full Width Image is disabled"
    },
    {
      "type": "checkbox",
      "id": "show_fallback",
      "label": "Show Fallback Content",
      "default": false,
      "info": "Display fallback content if variant doesn't have this metafield"
    },
    {
      "type": "richtext",
      "id": "fallback_content",
      "label": "Fallback Content",
      "info": "Content to display if the variant metafield is empty"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Variant Metafield Display"
    }
  ]
}
{% endschema %}

